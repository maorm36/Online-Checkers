<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - משחק דמקה</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css" rel="stylesheet" />
    <style>
        body {
            background-color: #f8f9fa;
        }
        .navbar-brand {
            font-weight: bold;
            font-size: 1.5rem;
        }
        .card {
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            border: none;
        }
        .btn-primary {
            background-color: #2c3e50;
            border-color: #2c3e50;
        }
        .btn-primary:hover {
            background-color: #34495e;
            border-color: #34495e;
        }
        .table th {
            background-color: #2c3e50;
            color: white;
        }
        .validation-summary-errors {
            color: #dc3545;
            background-color: #f8d7da;
            padding: 10px;
            border-radius: 5px;
            margin-bottom: 15px;
        }
        .field-validation-error {
            color: #dc3545;
            font-size: 0.875rem;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand" asp-page="/Index">🎮 משחק דמקה</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Index">דף הבית</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Register">הרשמה</a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                            שאילתות
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" asp-page="/Queries/AllPlayers">כל השחקנים</a></li>
                            <li><a class="dropdown-item" asp-page="/Queries/PlayersLastGame">שחקנים ומשחק אחרון</a></li>
                            <li><a class="dropdown-item" asp-page="/Queries/AllGames">כל המשחקים</a></li>
                            <li><a class="dropdown-item" asp-page="/Queries/FirstFromCountry">ראשון מכל מדינה</a></li>
                            <li><a class="dropdown-item" asp-page="/Queries/PlayerGames">משחקי שחקן</a></li>
                            <li><a class="dropdown-item" asp-page="/Queries/GamesCount">כמות משחקים לשחקן</a></li>
                            <li><a class="dropdown-item" asp-page="/Queries/GroupByGamesCount">קיבוץ לפי כמות</a></li>
                            <li><a class="dropdown-item" asp-page="/Queries/GroupByCountry">קיבוץ לפי מדינה</a></li>
                            <li><a class="dropdown-item" asp-page="/Queries/TopCountries">מדינות מובילות</a></li>
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                            עדכונים
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" asp-page="/Update/UpdatePlayer">עדכון שחקן</a></li>
                            <li><a class="dropdown-item" asp-page="/Update/DeletePlayer">מחיקת שחקן</a></li>
                            <li><a class="dropdown-item" asp-page="/Update/DeleteGame">מחיקת משחק</a></li>
                        </ul>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/About">אודות</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="footer mt-5 py-3 bg-dark">
        <div class="container text-center text-white">
            <span>© 2026 משחק דמקה - עבודת גמר הנדסת תוכנה</span>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
