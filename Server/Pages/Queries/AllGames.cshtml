@page
@model CheckersServer.Pages.Queries.AllGamesModel
@{
    ViewData["Title"] = "כל המשחקים";
}

<div class="card">
    <div class="card-header bg-primary text-white">
        <h2 class="mb-0">🎮 כל המשחקים</h2>
    </div>
    <div class="card-body">
        @if (Model.Games.Any())
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>מזהה משחק</th>
                            <th>שם שחקן</th>
                            <th>תחילת משחק</th>
                            <th>סיום משחק</th>
                            <th>משך זמן</th>
                            <th>תוצאה</th>
                            <th>מגבלת זמן (שניות)</th>
                            <th>רמת קושי</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var game in Model.Games)
                        {
                            <tr>
                                <td>@game.GameId</td>
                                <td>@game.PlayerName</td>
                                <td dir="ltr">@game.StartTime.ToString("dd/MM/yyyy HH:mm")</td>
                                <td dir="ltr">@(game.EndTime?.ToString("dd/MM/yyyy HH:mm") ?? "בתהליך")</td>
                                <td>@(game.Duration?.ToString(@"hh\:mm\:ss") ?? "-")</td>
                                <td>
                                    @switch (game.Result)
                                    {
                                        case "Win":
                                            <span class="badge bg-success">ניצחון</span>
                                            break;
                                        case "Loss":
                                            <span class="badge bg-danger">הפסד</span>
                                            break;
                                        default:
                                            <span class="badge bg-warning">בתהליך</span>
                                            break;
                                    }
                                </td>
                                <td>@game.TimeLimitSeconds</td>
                                <td>@game.Difficulty</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <p class="text-muted mt-2">סה"כ: @Model.Games.Count משחקים</p>
        }
        else
        {
            <div class="alert alert-info">
                אין משחקים במערכת
            </div>
        }
    </div>
</div>
