@page
@model CheckersServer.Pages.Queries.FirstFromCountryModel
@{
    ViewData["Title"] = "ראשון מכל מדינה";
}

<div class="card">
    <div class="card-header bg-primary text-white">
        <h2 class="mb-0">🌍 השחקן הראשון מכל מדינה</h2>
    </div>
    <div class="card-body">
        <p class="text-muted">מציג את השחקן הראשון ששיחק אי פעם מכל מדינה</p>

        @if (Model.Players.Any())
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>מדינה</th>
                            <th>שם שחקן</th>
                            <th>מס' מזהה</th>
                            <th>תאריך משחק ראשון</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var player in Model.Players)
                        {
                            <tr>
                                <td>@player.CountryName</td>
                                <td>@player.FirstName</td>
                                <td>@player.IdentificationNumber</td>
                                <td dir="ltr">@player.FirstGameDate.ToString("dd/MM/yyyy HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <p class="text-muted mt-2">סה"כ: @Model.Players.Count מדינות</p>
        }
        else
        {
            <div class="alert alert-info">
                אין שחקנים ששיחקו עדיין
            </div>
        }
    </div>
</div>