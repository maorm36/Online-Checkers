@page
@model CheckersServer.Pages.Queries.TopCountriesModel
@{
    ViewData["Title"] = "מדינות מובילות";
}

<div class="card">
    <div class="card-header bg-primary text-white">
        <h2 class="mb-0">🏆 שתי המדינות המובילות</h2>
    </div>
    <div class="card-body">
        <p class="text-muted">שתי המדינות מהן שוחקו הכי הרבה משחקים (שתי עמודות בלבד)</p>

        @if (Model.TopCountries.Any())
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>מדינה</th>
                            <th>מספר משחקים</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var country in Model.TopCountries)
                        {
                            <tr>
                                <td>
                                    @if (country == Model.TopCountries.First())
                                    {
                                        <span class="badge bg-warning text-dark me-2">🥇</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary me-2">🥈</span>
                                    }
                                    @country.CountryName
                                </td>
                                <td>@country.GamesCount</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="alert alert-info">
                אין משחקים במערכת
            </div>
        }
    </div>
</div>
