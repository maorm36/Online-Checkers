@page
@model CheckersServer.Pages.Update.DeletePlayerModel
@{
    ViewData["Title"] = "מחיקת שחקן";
}

<div class="card">
    <div class="card-header bg-danger text-white">
        <h2 class="mb-0">🗑️ מחיקת שחקן</h2>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="alert alert-success">
                @Model.SuccessMessage
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">
                @Model.ErrorMessage
            </div>
        }

        <div class="alert alert-warning">
            <strong>שים לב:</strong> מחיקת שחקן תמחק גם את כל המשחקים שלו!
        </div>

        <form method="post">
            <div class="row mb-4">
                <div class="col-md-6">
                    <label class="form-label">בחר שחקן למחיקה:</label>
                    <select asp-for="SelectedPlayerId" asp-items="Model.PlayerList" class="form-select">
                        <option value="">-- בחר שחקן --</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-danger" onclick="return confirm('האם אתה בטוח שברצונך למחוק את השחקן? פעולה זו תמחק גם את כל המשחקים שלו!');">
                        מחק שחקן
                    </button>
                </div>
            </div>
        </form>

        @if (Model.Players.Any())
        {
            <hr />
            <h4>רשימת השחקנים במערכת:</h4>
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>מס' מזהה</th>
                            <th>שם</th>
                            <th>טלפון</th>
                            <th>מדינה</th>
                            <th>משחקים</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var player in Model.Players)
                        {
                            <tr>
                                <td>@player.IdentificationNumber</td>
                                <td>@player.FirstName</td>
                                <td dir="ltr">@player.Phone</td>
                                <td>@player.CountryName</td>
                                <td>@player.GamesCount</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
